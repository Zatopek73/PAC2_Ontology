  "@id" : "http://www.semanticweb.org/pablo/ontologies/2026/3/PAC2_Ontology#",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "It is intended to formalize and categorize knowledge about the European catalog of high-risk medical devices and in vitro diagnostic devices according to their MDR (EU 2017/745) and IVDR (EU 2017/746) regulatory frameworks. The objective of this ontology is to structure and relate the information coming from the EUDAMED public repository covering the entire regulated part of the life cycle of the devices (Manufacturing, risk classification according to regulations and monitoring of their service (incidents and corrective actions)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "European Medical Device Ontology (MDR-IVDR)."
  } ]
