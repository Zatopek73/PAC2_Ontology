}, {
  "@id" : "https://zatopek73.github.io/PAC2_Ontology",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/bibliographicCitation" : [ {
    "@value" : "Parrado Gamito, P. (2026). European Medical Device Ontology (MDR-IVDR), version 1.0.0. https://zatopek73.github.io/PAC2_Ontology/"
  } ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@value" : "Pablo Parrado Gamito"
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#dateTime",
    "@value" : "2026-04-17T00:00:00"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Pablo Parrado Gamito"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "It is intended to formalize and categorize knowledge about the European catalog of high-risk medical devices and in vitro diagnostic devices according to their MDR (EU 2017/745) and IVDR (EU 2017/746) regulatory frameworks. The objective of this ontology is to structure and relate the information coming from the EUDAMED public repository covering the entire regulated part of the life cycle of the devices (Manufacturing, risk classification according to regulations and monitoring of their service (incidents and corrective actions)."
  } ],
  "http://purl.org/dc/terms/issued" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#dateTime",
    "@value" : "2026-04-17T00:00:00"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@value" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/publisher" : [ {
    "@value" : "Pablo Parrado Gamito (UOC)"
  } ],
  "http://purl.org/dc/terms/references" : [ {
    "@value" : "Dataset provided in the assignment (dades.xlsx)\nDBpedia (https://dbpedia.org)\nLinked Open Vocabularies (https://lov.linkeddata.es)\nEU Vocabularies (https://op.europa.eu)"
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "Dataset provided in the assignment (PAC2_Data.zip).\nhttps://dbpedia.org\nhttps://lov.linkeddata\nhttps://op.europa.eu"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "European Medical Device Ontology (MDR-IVDR)"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "pac2"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
