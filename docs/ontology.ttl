@prefix : <https://zatopek73.github.io/PAC2_Ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://zatopek73.github.io/PAC2_Ontology#> .

<https://zatopek73.github.io/PAC2_Ontology> rdf:type owl:Ontology ;
                                             owl:versionIRI <https://zatopek73.github.io/PAC2_Ontology/1.0.0> ;
                                             <http://purl.org/dc/terms/bibliographicCitation> "Parrado Gamito, P. (2026). European Medical Device Ontology (MDR-IVDR), version 1.0.0. https://zatopek73.github.io/PAC2_Ontology/" ;
                                             <http://purl.org/dc/terms/contributor> "Pablo Parrado Gamito" ;
                                             <http://purl.org/dc/terms/created> "2026-04-17T00:00:00"^^xsd:dateTime ;
                                             <http://purl.org/dc/terms/creator> "Pablo Parrado Gamito" ;
                                             <http://purl.org/dc/terms/description> "It is intended to formalize and categorize knowledge about the European catalog of high-risk medical devices and in vitro diagnostic devices according to their MDR (EU 2017/745) and IVDR (EU 2017/746) regulatory frameworks. The objective of this ontology is to structure and relate the information coming from the EUDAMED public repository covering the entire regulated part of the life cycle of the devices (Manufacturing, risk classification according to regulations and monitoring of their service (incidents and corrective actions)." ;
                                             <http://purl.org/dc/terms/issued> "2026-04-17T00:00:00"^^xsd:dateTime ;
                                             <http://purl.org/dc/terms/license> "https://creativecommons.org/licenses/by/4.0/" ;
                                             <http://purl.org/dc/terms/publisher> "Pablo Parrado Gamito (UOC)" ;
                                             <http://purl.org/dc/terms/references> """Dataset provided in the assignment (dades.xlsx)
DBpedia (https://dbpedia.org)
Linked Open Vocabularies (https://lov.linkeddata.es)
EU Vocabularies (https://op.europa.eu)""" ;
                                             <http://purl.org/dc/terms/source> """Dataset provided in the assignment (PAC2_Data.zip).
https://dbpedia.org
https://lov.linkeddata
https://op.europa.eu""" ;
                                             <http://purl.org/dc/terms/title> "European Medical Device Ontology (MDR-IVDR)" ;
                                             <http://purl.org/vocab/vann/preferredNamespacePrefix> "pac2" ;
                                             <http://purl.org/vocab/vann/preferredNamespaceUri> "https://zatopek73.github.io/PAC2_Ontology#" ;
                                             rdfs:label "European Medical Device Ontology (MDR-IVDR)." ;
                                             owl:versionInfo "1.0.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/bibliographicCitation
<http://purl.org/dc/terms/bibliographicCitation> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/references
<http://purl.org/dc/terms/references> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/source
<http://purl.org/dc/terms/source> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:AnnotationProperty .


###  https://zatopek73.github.io/PAC2_Ontologyvann:preferredNamespacePrefix
<https://zatopek73.github.io/PAC2_Ontologyvann:preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  https://zatopek73.github.io/PAC2_Ontologyvann:preferredNamespaceUri
<https://zatopek73.github.io/PAC2_Ontologyvann:preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://zatopek73.github.io/PAC2_Ontology#affectsDeviceType
:affectsDeviceType rdf:type owl:ObjectProperty ;
                   rdfs:domain :Risk ;
                   rdfs:range :DeviceType ;
                   rdfs:comment "Relates a risk to the type of device it affects. Used to infer associations between risks and devices." ;
                   rdfs:label "affects device type" .


###  https://zatopek73.github.io/PAC2_Ontology#causesRisk
:causesRisk rdf:type owl:ObjectProperty ,
                     owl:TransitiveProperty ;
            rdfs:domain :Risk ;
            rdfs:range :Risk ;
            rdfs:comment "Relates a risk to another risk that it causes. This property is transitive." ;
            rdfs:label "causes risk" .


###  https://zatopek73.github.io/PAC2_Ontology#hasAssociatedRisk
:hasAssociatedRisk rdf:type owl:ObjectProperty ,
                            owl:AsymmetricProperty ;
                   rdfs:domain :Device ;
                   rdfs:range :Risk ;
                   rdfs:comment "Relates a device to risks associated with it. This relationship is derived from the correspondence between device types and affected device types." ;
                   rdfs:label "has associated risk" .


###  https://zatopek73.github.io/PAC2_Ontology#hasCorrectiveActionStatus
:hasCorrectiveActionStatus rdf:type owl:ObjectProperty ,
                                    owl:FunctionalProperty ;
                           rdfs:domain :CorrectiveActions ;
                           rdfs:range :CorrectiveActionStatus ;
                           rdfs:comment "Relates a corrective action to its status, represented as a controlled vocabulary." ;
                           rdfs:label "has corrective action status" .


###  https://zatopek73.github.io/PAC2_Ontology#hasDeviceRiskClass
:hasDeviceRiskClass rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Device ;
                    rdfs:range :DeviceRiskClass ;
                    rdfs:comment "Relates a device to its regulatory risk classification." ;
                    rdfs:label "has device risk class" .


###  https://zatopek73.github.io/PAC2_Ontology#hasDeviceType
:hasDeviceType rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Device ;
               rdfs:range :DeviceType ;
               rdfs:comment "Relates a device to its device type. This classification enables linking devices with risks." ;
               rdfs:label "has device type" .


###  https://zatopek73.github.io/PAC2_Ontology#hasIncidentPatientSex
:hasIncidentPatientSex rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range :IncidentPatientSex ;
                       rdfs:comment "Relates an incident to the patient's sex category, represented as a controlled vocabulary." ;
                       rdfs:label "has incident patient sex" .


###  https://zatopek73.github.io/PAC2_Ontology#hasIncidentType
:hasIncidentType rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range :IncidentType ;
                 rdfs:comment "Relates an incident to its type, modelled as a controlled classification." ;
                 rdfs:label "has incident type" .


###  https://zatopek73.github.io/PAC2_Ontology#hasManufacturedBy
:hasManufacturedBy rdf:type owl:ObjectProperty ;
                   rdfs:domain :Device ;
                   rdfs:range :Manufacturer ;
                   rdfs:comment "Relates a device to its manufacturer. Each device is associated with exactly one manufacturer." ;
                   rdfs:label "has manufactured by" .


###  https://zatopek73.github.io/PAC2_Ontology#hasRiskCategory
:hasRiskCategory rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range :RiskCategory ;
                 rdfs:comment "Relates a risk to its category. This classification is aligned with controlled vocabularies similar to skos:Concept." ;
                 rdfs:label "has risk category" .


###  https://zatopek73.github.io/PAC2_Ontology#isAboutDevice
:isAboutDevice rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Incident ;
               rdfs:range :Device ;
               rdfs:comment "Relates an incident to the device involved. Each incident refers to exactly one device." ;
               rdfs:label "is about device" .


###  https://zatopek73.github.io/PAC2_Ontology#isAboutRisk
:isAboutRisk rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Incident ;
             rdfs:range :Risk ;
             rdfs:comment "Relates an incident to the associated risk. Each incident is linked to exactly one risk." ;
             rdfs:label "is about risk" .


###  https://zatopek73.github.io/PAC2_Ontology#isBasedIn
:isBasedIn rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Manufacturer ;
           rdfs:range :Country ;
           rdfs:comment "Relates a manufacturer to the country where it is based." ;
           rdfs:label "is based in" .


###  https://zatopek73.github.io/PAC2_Ontology#isReportedBy
:isReportedBy rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Incident ;
              rdfs:range :Manufacturer ;
              rdfs:comment "Relates an incident to the reporting entity, modelled as a manufacturer in this ontology." ;
              rdfs:label "is reported by" .


###  https://zatopek73.github.io/PAC2_Ontology#isReportedIn
:isReportedIn rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Incident ;
              rdfs:range :Country ;
              rdfs:comment "Relates an incident to the country where it is reported. Each incident is associated with exactly one country." ;
              rdfs:label "is reported in" .


###  https://zatopek73.github.io/PAC2_Ontology#isResponseTo
:isResponseTo rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :CorrectiveActions ;
              rdfs:range :Incident ;
              rdfs:comment "Relates a corrective action to the incident it addresses. Each corrective action corresponds to exactly one incident." ;
              rdfs:label "is response to" .


#################################################################
#    Data properties
#################################################################

###  https://zatopek73.github.io/PAC2_Ontology#hasActionCountriesAffected
:hasActionCountriesAffected rdf:type owl:DatatypeProperty ;
                            rdfs:domain :CorrectiveActions ;
                            rdfs:range xsd:string ;
                            rdfs:comment "Group of countries affected by the corrective action, represented as a group value." ;
                            rdfs:label "has action countries affected" .


###  https://zatopek73.github.io/PAC2_Ontology#hasActionDate
:hasActionDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :CorrectiveActions ;
               rdfs:range xsd:dateTime ;
               rdfs:comment "Date when the corrective action was initiated. Aligned with dcterms:date." ;
               rdfs:label "has action date" .


###  https://zatopek73.github.io/PAC2_Ontology#hasActionDescription
:hasActionDescription rdf:type owl:DatatypeProperty ;
                      rdfs:domain :CorrectiveActions ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Textual description of a corrective action. Aligned with dcterms:description." ;
                      rdfs:label "has action description" .


###  https://zatopek73.github.io/PAC2_Ontology#hasActionDevicesAffected
:hasActionDevicesAffected rdf:type owl:DatatypeProperty ;
                          rdfs:domain :CorrectiveActions ;
                          rdfs:range xsd:int ;
                          rdfs:comment "Number of devices affected by the corrective action." ;
                          rdfs:label "has action devices affected" .


###  https://zatopek73.github.io/PAC2_Ontology#hasActionEudamedFscaRef
:hasActionEudamedFscaRef rdf:type owl:DatatypeProperty ;
                         rdfs:domain :CorrectiveActions ;
                         rdfs:range xsd:string ;
                         rdfs:comment "Stores the Eudamed Fsca Refence number." ;
                         rdfs:label "has action Eudamed Fsca Ref" .


###  https://zatopek73.github.io/PAC2_Ontology#hasActionFscaId
:hasActionFscaId rdf:type owl:DatatypeProperty ;
                 rdfs:domain :CorrectiveActions ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Identifier of a corrective action. Aligned with dcterms:identifier." ;
                 rdfs:label "has action FscaId" .


###  https://zatopek73.github.io/PAC2_Ontology#hasActionType
:hasActionType rdf:type owl:DatatypeProperty ;
               rdfs:domain :CorrectiveActions ;
               rdfs:range xsd:string ;
               rdfs:comment "Stores the type of corrective action type" ;
               rdfs:label "has action type" .


###  https://zatopek73.github.io/PAC2_Ontology#hasClosureDate
:hasClosureDate rdf:type owl:DatatypeProperty ;
                rdfs:domain :CorrectiveActions ;
                rdfs:range xsd:dateTime ;
                rdfs:comment "Date when the corrective action was closed. Aligned with dcterms:date." ;
                rdfs:label "has clousure date" .


###  https://zatopek73.github.io/PAC2_Ontology#hasCorrectiveActionTaken
:hasCorrectiveActionTaken rdf:type owl:DatatypeProperty ;
                          rdfs:domain :Incident ;
                          rdfs:range xsd:boolean ;
                          rdfs:comment "Indicates whether a corrective action was taken for the incident." ;
                          rdfs:label "is corrective action taken" .


###  https://zatopek73.github.io/PAC2_Ontology#hasDeviceId
:hasDeviceId rdf:type owl:DatatypeProperty ;
             rdfs:domain :Device ;
             rdfs:range xsd:string ;
             rdfs:comment "Identifier of a device. Aligned with dcterms:identifier." ;
             rdfs:label "has device id" .


###  https://zatopek73.github.io/PAC2_Ontology#hasDeviceName
:hasDeviceName rdf:type owl:DatatypeProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:string ;
               rdfs:comment "Name of the device. Similar to rdfs:label." ;
               rdfs:label "device name" .


###  https://zatopek73.github.io/PAC2_Ontology#hasIncidentDescription
:hasIncidentDescription rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Incident ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Textual description of an incident. Aligned with dcterms:description." ;
                        rdfs:label "has incident description" .


###  https://zatopek73.github.io/PAC2_Ontology#hasIncidentDetectionDate
:hasIncidentDetectionDate rdf:type owl:DatatypeProperty ;
                          rdfs:domain :Incident ;
                          rdfs:range xsd:dateTime ;
                          rdfs:comment "Date when the incident was detected. Aligned with dcterms:date." ;
                          rdfs:label "has incident detection date" .


###  https://zatopek73.github.io/PAC2_Ontology#hasIncidentEudamedNum
:hasIncidentEudamedNum rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Stores the Eudamed incident num." ;
                       rdfs:label "has incident Eudamed num" .


###  https://zatopek73.github.io/PAC2_Ontology#hasIncidentId
:hasIncidentId rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:string ;
               rdfs:comment "Identifier of an incident. Aligned with dcterms:identifier." ;
               rdfs:label "has incident id" .


###  https://zatopek73.github.io/PAC2_Ontology#hasIncidentOutcome
:hasIncidentOutcome rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Outcome of the incident as a descriptive value." ;
                    rdfs:label "incident outcome" .


###  https://zatopek73.github.io/PAC2_Ontology#hasIncidentPatientAge
:hasIncidentPatientAge rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:int ;
                       rdfs:comment "Store the age of the patient affected." ;
                       rdfs:label "has incident patient age" .


###  https://zatopek73.github.io/PAC2_Ontology#hasIncidentReportDate
:hasIncidentReportDate rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:dateTime ;
                       rdfs:comment "Date when the incident was reported. Aligned with dcterms:date." ;
                       rdfs:label "has incident report date" .


###  https://zatopek73.github.io/PAC2_Ontology#hasIntendedPurpose
:hasIntendedPurpose rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Device ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Stores the purpose" ;
                    rdfs:label "has intended purpose" .


###  https://zatopek73.github.io/PAC2_Ontology#hasManufacturerAuthNumber
:hasManufacturerAuthNumber rdf:type owl:DatatypeProperty ;
                           rdfs:domain :Manufacturer ;
                           rdfs:range xsd:string ;
                           rdfs:comment "Stores the manufacturer's authorization number." ;
                           rdfs:label "has manufacturer auth number." .


###  https://zatopek73.github.io/PAC2_Ontology#hasManufacturerCompetentAutority
:hasManufacturerCompetentAutority rdf:type owl:DatatypeProperty ;
                                  rdfs:domain :Manufacturer ;
                                  rdfs:range xsd:string ;
                                  rdfs:comment "Stores the manufacturer competent autority." ;
                                  rdfs:label "has manufacturer competent autority" .


###  https://zatopek73.github.io/PAC2_Ontology#hasManufacturerEmail
:hasManufacturerEmail rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Manufacturer ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Email address of the manufacturer. Conceptually aligned with foaf:mbox." ;
                      rdfs:label "has manufacturer email" .


###  https://zatopek73.github.io/PAC2_Ontology#hasManufacturerEudamedSn
:hasManufacturerEudamedSn rdf:type owl:DatatypeProperty ;
                          rdfs:domain :Manufacturer ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Stores the Eudamed sn" ;
                          rdfs:label "has manufacturer Eudamed sn" .


###  https://zatopek73.github.io/PAC2_Ontology#hasManufacturerId
:hasManufacturerId rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Manufacturer ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Identifier of a manufacturer. Aligned with dcterms:identifier." ;
                   rdfs:label "has manufacturer id" .


###  https://zatopek73.github.io/PAC2_Ontology#hasManufacturerName
:hasManufacturerName rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Name of the manufacturer. Conceptually aligned with foaf:name." ;
                     rdfs:label "has manufacturer name" .


###  https://zatopek73.github.io/PAC2_Ontology#hasRiskDescription
:hasRiskDescription rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Textual description of a risk. Aligned with dcterms:description." ;
                    rdfs:label "has risk description" .


###  https://zatopek73.github.io/PAC2_Ontology#hasRiskId
:hasRiskId rdf:type owl:DatatypeProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "Identifier of a risk. Aligned with dcterms:identifier." ;
           rdfs:label "has risk id" .


###  https://zatopek73.github.io/PAC2_Ontology#hasRiskImdrfCode
:hasRiskImdrfCode rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Risk ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Stores the imdrf code." ;
                  rdfs:label "has risk imdrf code" .


###  https://zatopek73.github.io/PAC2_Ontology#hasRiskName
:hasRiskName rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "Stores the risk name." ;
             rdfs:label "has risk name" .


###  https://zatopek73.github.io/PAC2_Ontology#hasRiskType
:hasRiskType rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "Type of risk represented as a literal value. Not modelled as a separate ontology concept." ;
             rdfs:label "has risk type" .


###  https://zatopek73.github.io/PAC2_Ontology#hasUdi_di
:hasUdi_di rdf:type owl:DatatypeProperty ;
           rdfs:domain :Device ;
           rdfs:range xsd:string ;
           rdfs:comment "Stores the udi_di reference" ;
           rdfs:label "has udi_di" .


###  https://zatopek73.github.io/PAC2_Ontology#isDeviceActive
:isDeviceActive rdf:type owl:DatatypeProperty ;
                rdfs:domain :Device ;
                rdfs:range xsd:boolean ;
                rdfs:comment "store the device status" ;
                rdfs:label "is device active" .


###  https://zatopek73.github.io/PAC2_Ontology#isDeviceImplantable
:isDeviceImplantable rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Device ;
                     rdfs:range xsd:boolean ;
                     rdfs:comment "store if the device is implantable or not." ;
                     rdfs:label "is device implantable" .


###  https://zatopek73.github.io/PAC2_Ontology#isDeviceIvd
:isDeviceIvd rdf:type owl:DatatypeProperty ;
             rdfs:domain :Device ;
             rdfs:range xsd:boolean ;
             rdfs:comment "Stores if the device is Invitro Device or not" ;
             rdfs:label "is device idv" .


###  https://zatopek73.github.io/PAC2_Ontology#isDeviceRegulatoryId
:isDeviceRegulatoryId rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Device ;
                      rdfs:range xsd:string ;
                      rdfs:comment "The regulatory framework of the device (MDR or IVDR)" ;
                      rdfs:label "is device regulatory" .


###  https://zatopek73.github.io/PAC2_Ontology#isDeviceReusable
:isDeviceReusable rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Device ;
                  rdfs:range xsd:boolean ;
                  rdfs:comment "Stores if the device is reusable or not" ;
                  rdfs:label "is device reusable" .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2003/11/swrl#AtomList
<http://www.w3.org/2003/11/swrl#AtomList> rdf:type owl:Class ;
                                          rdfs:comment "Represents a SWRL rule." ;
                                          rdfs:label "SWRL Rule" .


###  http://www.w3.org/2003/11/swrl#ClassAtom
<http://www.w3.org/2003/11/swrl#ClassAtom> rdf:type owl:Class ;
                                           rdfs:comment "Represents a SWRL rule." ;
                                           rdfs:label "SWRL Rule" .


###  http://www.w3.org/2003/11/swrl#Imp
<http://www.w3.org/2003/11/swrl#Imp> rdf:type owl:Class ;
                                     rdfs:comment "Represents a SWRL rule." ;
                                     rdfs:label "SWRL Rule" .


###  http://www.w3.org/2003/11/swrl#IndividualPropertyAtom
<http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> rdf:type owl:Class ;
                                                        rdfs:comment "Represents a SWRL rule." ;
                                                        rdfs:label "SWRL Rule" .


###  http://www.w3.org/2003/11/swrl#Variable
<http://www.w3.org/2003/11/swrl#Variable> rdf:type owl:Class ;
                                          rdfs:comment "Represents a SWRL rule." ;
                                          rdfs:label "SWRL Rule" .


###  https://zatopek73.github.io/PAC2_Ontology#CorrectiveActionStatus
:CorrectiveActionStatus rdf:type owl:Class ;
                        rdfs:comment "Class representing the status of a corrective action. Modelled as a controlled vocabulary." ;
                        rdfs:label "Corrective status" .


###  https://zatopek73.github.io/PAC2_Ontology#CorrectiveActions
:CorrectiveActions rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty :isResponseTo ;
                                     owl:someValuesFrom :Incident
                                   ] ;
                   rdfs:comment "Class representing corrective actions taken in response to incidents. Descriptions and dates are aligned with Dublin Core terms." ;
                   rdfs:label "Corrective Actions" .


###  https://zatopek73.github.io/PAC2_Ontology#Country
:Country rdf:type owl:Class ;
         rdfs:comment "Class representing a country associated with reporting or manufacturer location. Conceptually aligned with EU controlled vocabularies for countries." ;
         rdfs:label "Country" .


###  https://zatopek73.github.io/PAC2_Ontology#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturedBy ;
                          owl:someValuesFrom :Manufacturer
                        ] ;
        rdfs:comment "Class representing a medical device within the surveillance domain. Device identifiers are aligned with dcterms:identifier." ;
        rdfs:label "Device" .


###  https://zatopek73.github.io/PAC2_Ontology#DeviceRiskClass
:DeviceRiskClass rdf:type owl:Class ;
                 rdfs:comment "Class representing the regulatory risk classification of a device. Modelled as a controlled classification." ;
                 rdfs:label "Device risk class" .


###  https://zatopek73.github.io/PAC2_Ontology#DeviceType
:DeviceType rdf:type owl:Class ;
            rdfs:comment "Device type about interaction with patient (Active,Implantable,invitro,single use, etc.)" ;
            rdfs:label "Device type" .


###  https://zatopek73.github.io/PAC2_Ontology#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :isAboutDevice ;
                            owl:someValuesFrom :Device
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :isReportedIn ;
                            owl:allValuesFrom :Country
                          ] ;
          rdfs:comment "Class representing an incident involving a medical device. Temporal properties are aligned with dcterms:date." ;
          rdfs:label "Incident" .


###  https://zatopek73.github.io/PAC2_Ontology#IncidentPatientSex
:IncidentPatientSex rdf:type owl:Class ;
                    rdfs:comment "Class representing the sex category of a patient involved in an incident. Modelled as a controlled vocabulary." ;
                    rdfs:label "Incident patient sex" .


###  https://zatopek73.github.io/PAC2_Ontology#IncidentType
:IncidentType rdf:type owl:Class ;
              rdfs:comment "Class representing the type of incident. Modelled as a controlled classification similar to skos:Concept." ;
              rdfs:label "Incident type" .


###  https://zatopek73.github.io/PAC2_Ontology#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :isBasedIn ;
                                owl:someValuesFrom :Country
                              ] ;
              rdfs:comment "Class representing the manufacturer of a medical device. Conceptually aligned with foaf:Organization." ;
              rdfs:label "Manufacturer" .


###  https://zatopek73.github.io/PAC2_Ontology#Risk
:Risk rdf:type owl:Class ;
      rdfs:comment "Class representing a risk associated with a device or incident. Risk descriptions are aligned with dcterms:description." ;
      rdfs:label "Risk" .


###  https://zatopek73.github.io/PAC2_Ontology#RiskCategory
:RiskCategory rdf:type owl:Class ;
              rdfs:comment "Class representing the category assigned to a risk. Conceptually aligned with skos:Concept for classification purposes." ;
              rdfs:label "Risk Category" .


