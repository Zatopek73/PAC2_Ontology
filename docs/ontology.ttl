#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :CorrectiveActionStatus
                :CorrectiveActions
                :Country
                :Device
                :DeviceRiskClass
                :DeviceType
                :Incident
                :IncidentPatientSex
                :IncidentType
                :Manufacturer
                :Risk
                :RiskCategory
              )
] .


#################################################################
#    Rules
#################################################################

<https://zatopek73.github.io/PAC2_Ontology#/i> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<https://zatopek73.github.io/PAC2_Ontology#/d> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<https://zatopek73.github.io/PAC2_Ontology#/m> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<https://zatopek73.github.io/PAC2_Ontology#/r> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<https://zatopek73.github.io/PAC2_Ontology#/c> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<https://zatopek73.github.io/PAC2_Ontology#/dt> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "Infers the reporting manufacturer of an incident based on the device manufacturer." ;
   rdfs:label "S2" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :Incident ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <https://zatopek73.github.io/PAC2_Ontology#/i>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :isAboutDevice ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <https://zatopek73.github.io/PAC2_Ontology#/i> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <https://zatopek73.github.io/PAC2_Ontology#/d>
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasManufacturedBy ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <https://zatopek73.github.io/PAC2_Ontology#/d> ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> <https://zatopek73.github.io/PAC2_Ontology#/m>
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :isReportedBy ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <https://zatopek73.github.io/PAC2_Ontology#/i> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <https://zatopek73.github.io/PAC2_Ontology#/m>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "Infers the risk associated with an incident based on the risks of the involved device." ;
   rdfs:label "S1" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
