#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2003/11/swrl#AtomList
<http://www.w3.org/2003/11/swrl#AtomList> rdf:type owl:Class ;
                                          rdfs:comment "Represents a SWRL rule." ;
                                          rdfs:label "SWRL Rule" .


###  http://www.w3.org/2003/11/swrl#ClassAtom
<http://www.w3.org/2003/11/swrl#ClassAtom> rdf:type owl:Class ;
                                           rdfs:comment "Represents a SWRL rule." ;
                                           rdfs:label "SWRL Rule" .


###  http://www.w3.org/2003/11/swrl#Imp
<http://www.w3.org/2003/11/swrl#Imp> rdf:type owl:Class ;
                                     rdfs:comment "Represents a SWRL rule." ;
                                     rdfs:label "SWRL Rule" .


###  http://www.w3.org/2003/11/swrl#IndividualPropertyAtom
<http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> rdf:type owl:Class ;
                                                        rdfs:comment "Represents a SWRL rule." ;
                                                        rdfs:label "SWRL Rule" .


###  http://www.w3.org/2003/11/swrl#Variable
<http://www.w3.org/2003/11/swrl#Variable> rdf:type owl:Class ;
                                          rdfs:comment "Represents a SWRL rule." ;
                                          rdfs:label "SWRL Rule" .


###  http://www.w3.org/2004/02/skos/core#Collection
<http://www.w3.org/2004/02/skos/core#Collection> rdf:type owl:Class ;
                                                 owl:disjointWith <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                  <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 rdfs:label "Collection"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "A meaningful collection of concepts."@en ;
                                                 <http://www.w3.org/2004/02/skos/core#scopeNote> "Labelled collections can be used where you would like a set of concepts to be displayed under a 'node label' in the hierarchy."@en .


###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class ;
                                              owl:disjointWith <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                              rdfs:label "Concept"@en ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "An idea or notion; a unit of thought."@en .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
<http://www.w3.org/2004/02/skos/core#ConceptScheme> rdf:type owl:Class ;
                                                    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                    rdfs:label "Concept Scheme"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "A set of concepts, optionally including statements about semantic relationships between those concepts."@en ;
                                                    <http://www.w3.org/2004/02/skos/core#example> "Thesauri, classification schemes, subject heading lists, taxonomies, 'folksonomies', and other types of controlled vocabulary are all examples of concept schemes. Concept schemes are also embedded in glossaries and terminologies."@en ;
                                                    <http://www.w3.org/2004/02/skos/core#scopeNote> "A concept scheme may be defined to include concepts from different sources."@en .


###  http://www.w3.org/2004/02/skos/core#OrderedCollection
<http://www.w3.org/2004/02/skos/core#OrderedCollection> rdf:type owl:Class ;
                                                        rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Collection> ;
                                                        rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                        rdfs:label "Ordered Collection"@en ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "An ordered collection of concepts, where both the grouping and the ordering are meaningful."@en ;
                                                        <http://www.w3.org/2004/02/skos/core#scopeNote> "Ordered collections can be used where you would like a set of concepts to be displayed in a specific order, and optionally under a 'node label'."@en .


###  https://zatopek73.github.io/PAC2_Ontology#CorrectiveActionStatus
:CorrectiveActionStatus rdf:type owl:Class ;
                        rdfs:comment "Class representing the status of a corrective action. Modelled as a controlled vocabulary." ;
                        rdfs:label "Corrective status" .


###  https://zatopek73.github.io/PAC2_Ontology#CorrectiveActions
:CorrectiveActions rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty :isResponseTo ;
                                     owl:someValuesFrom :Incident
                                   ] ;
                   rdfs:comment "Class representing corrective actions taken in response to incidents. Descriptions and dates are aligned with Dublin Core terms." ;
                   rdfs:label "Corrective Actions" .


###  https://zatopek73.github.io/PAC2_Ontology#Country
:Country rdf:type owl:Class ;
         rdfs:comment "Class representing a country associated with reporting or manufacturer location. Conceptually aligned with EU controlled vocabularies for countries." ;
         rdfs:label "Country" .


###  https://zatopek73.github.io/PAC2_Ontology#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturedBy ;
                          owl:someValuesFrom :Manufacturer
                        ] ;
        rdfs:comment "Class representing a medical device within the surveillance domain. Device identifiers are aligned with dcterms:identifier." ;
        rdfs:label "Device" .


###  https://zatopek73.github.io/PAC2_Ontology#DeviceRiskClass
:DeviceRiskClass rdf:type owl:Class ;
                 rdfs:comment "Class representing the regulatory risk classification of a device. Modelled as a controlled classification." ;
                 rdfs:label "Device risk class" .


###  https://zatopek73.github.io/PAC2_Ontology#DeviceType
:DeviceType rdf:type owl:Class ;
            rdfs:comment "Device type about interaction with patient (Active,Implantable,invitro,single use, etc.)" ;
            rdfs:label "Device type" .


###  https://zatopek73.github.io/PAC2_Ontology#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :isAboutDevice ;
                            owl:someValuesFrom :Device
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :isReportedIn ;
                            owl:allValuesFrom :Country
                          ] ;
          rdfs:comment "Class representing an incident involving a medical device. Temporal properties are aligned with dcterms:date." ;
          rdfs:label "Incident" .


###  https://zatopek73.github.io/PAC2_Ontology#IncidentPatientSex
:IncidentPatientSex rdf:type owl:Class ;
                    rdfs:comment "Class representing the sex category of a patient involved in an incident. Modelled as a controlled vocabulary." ;
                    rdfs:label "Incident patient sex" .


###  https://zatopek73.github.io/PAC2_Ontology#IncidentType
:IncidentType rdf:type owl:Class ;
              rdfs:comment "Class representing the type of incident. Modelled as a controlled classification similar to skos:Concept." ;
              rdfs:label "Incident type" .


###  https://zatopek73.github.io/PAC2_Ontology#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :isBasedIn ;
                                owl:someValuesFrom :Country
                              ] ;
              rdfs:comment "Class representing the manufacturer of a medical device. Conceptually aligned with foaf:Organization." ;
              rdfs:label "Manufacturer" .


###  https://zatopek73.github.io/PAC2_Ontology#RegulatoryFramework
:RegulatoryFramework rdf:type owl:Class ;
                     rdfs:comment "Class representing the regulatory framework assigned to a device." ;
                     rdfs:label "Regulatory Framework" .


###  https://zatopek73.github.io/PAC2_Ontology#Risk
:Risk rdf:type owl:Class ;
      rdfs:comment "Class representing a risk associated with a device or incident. Risk descriptions are aligned with dcterms:description." ;
      rdfs:label "Risk" .


###  https://zatopek73.github.io/PAC2_Ontology#RiskCategory
:RiskCategory rdf:type owl:Class ;
              rdfs:comment "Class representing the category assigned to a risk." ;
              rdfs:label "Risk Category" .


###  https://zatopek73.github.io/PAC2_Ontology#RiskProbability
:RiskProbability rdf:type owl:Class ;
                 rdfs:comment "Class representing the probability assigned to a risk." ;
                 rdfs:label "Risk Probability" .


###  https://zatopek73.github.io/PAC2_Ontology#RiskSeverity
:RiskSeverity rdf:type owl:Class ;
              rdfs:comment "Class representing the severity assigned to a risk." ;
              rdfs:label "Risk Severity" .


###  https://zatopek73.github.io/PAC2_Ontology#RiskType
:RiskType rdf:type owl:Class ;
          rdfs:comment "Class representing the type assigned to a risk." ;
          rdfs:label "Risk Type" .


