        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Collection"/>
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
    </rdf:Description>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#CorrectiveActionStatus -->

    <owl:Class rdf:about="https://zatopek73.github.io/PAC2_Ontology#CorrectiveActionStatus">
        <rdfs:comment>Class representing the status of a corrective action. Modelled as a controlled vocabulary.</rdfs:comment>
        <rdfs:label>Corrective status</rdfs:label>
    </owl:Class>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#CorrectiveActions -->

    <owl:Class rdf:about="https://zatopek73.github.io/PAC2_Ontology#CorrectiveActions">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://zatopek73.github.io/PAC2_Ontology#isResponseTo"/>
                <owl:someValuesFrom rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Class representing corrective actions taken in response to incidents. Descriptions and dates are aligned with Dublin Core terms.</rdfs:comment>
        <rdfs:label>Corrective Actions</rdfs:label>
    </owl:Class>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#Country -->

    <owl:Class rdf:about="https://zatopek73.github.io/PAC2_Ontology#Country">
        <rdfs:comment>Class representing a country associated with reporting or manufacturer location. Conceptually aligned with EU controlled vocabularies for countries.</rdfs:comment>
        <rdfs:label>Country</rdfs:label>
    </owl:Class>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#Device -->

    <owl:Class rdf:about="https://zatopek73.github.io/PAC2_Ontology#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://zatopek73.github.io/PAC2_Ontology#hasManufacturedBy"/>
                <owl:someValuesFrom rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Class representing a medical device within the surveillance domain. Device identifiers are aligned with dcterms:identifier.</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#DeviceRiskClass -->

    <owl:Class rdf:about="https://zatopek73.github.io/PAC2_Ontology#DeviceRiskClass">
        <rdfs:comment>Class representing the regulatory risk classification of a device. Modelled as a controlled classification.</rdfs:comment>
        <rdfs:label>Device risk class</rdfs:label>
    </owl:Class>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#DeviceType -->

    <owl:Class rdf:about="https://zatopek73.github.io/PAC2_Ontology#DeviceType">
        <rdfs:comment>Device type about interaction with patient (Active,Implantable,invitro,single use, etc.)</rdfs:comment>
        <rdfs:label>Device type</rdfs:label>
    </owl:Class>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#Incident -->

    <owl:Class rdf:about="https://zatopek73.github.io/PAC2_Ontology#Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://zatopek73.github.io/PAC2_Ontology#isAboutDevice"/>
                <owl:someValuesFrom rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Device"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://zatopek73.github.io/PAC2_Ontology#isReportedIn"/>
                <owl:allValuesFrom rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Country"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Class representing an incident involving a medical device. Temporal properties are aligned with dcterms:date.</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#IncidentPatientSex -->

    <owl:Class rdf:about="https://zatopek73.github.io/PAC2_Ontology#IncidentPatientSex">
        <rdfs:comment>Class representing the sex category of a patient involved in an incident. Modelled as a controlled vocabulary.</rdfs:comment>
        <rdfs:label>Incident patient sex</rdfs:label>
    </owl:Class>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#IncidentType -->

    <owl:Class rdf:about="https://zatopek73.github.io/PAC2_Ontology#IncidentType">
        <rdfs:comment>Class representing the type of incident. Modelled as a controlled classification similar to skos:Concept.</rdfs:comment>
        <rdfs:label>Incident type</rdfs:label>
    </owl:Class>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#Manufacturer -->

