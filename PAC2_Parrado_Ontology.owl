        </rdfs:subClassOf>
        <rdfs:comment>Class representing the manufacturer of a medical device. Conceptually aligned with foaf:Organization.</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
    </owl:Class>
    


