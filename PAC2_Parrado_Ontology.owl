        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://zatopek73.github.io/PAC2_Ontology#isBasedIn"/>
                <owl:someValuesFrom rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Country"/>
