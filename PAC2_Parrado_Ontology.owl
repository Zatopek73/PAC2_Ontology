<?xml version="1.0"?>
<rdf:RDF xmlns="https://zatopek73.github.io/PAC2_Ontology#"
     xml:base="https://zatopek73.github.io/PAC2_Ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:vann1="https://zatopek73.github.io/PAC2_Ontology/vann:"
     xmlns:vann2="vann:"
     xmlns:PAC2_Ontology="https://zatopek73.github.io/PAC2_Ontology#"
     xmlns:PAC2_Ontologyvann="https://zatopek73.github.io/PAC2_Ontologyvann:">
    <owl:Ontology rdf:about="https://zatopek73.github.io/PAC2_Ontology">
        <owl:versionIRI rdf:resource="https://zatopek73.github.io/PAC2_Ontology/1.0.0"/>
        <owl:imports rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <terms:bibliographicCitation>Parrado Gamito, P. (2026). European Medical Device Ontology (MDR-IVDR), version 1.0.0. https://zatopek73.github.io/PAC2_Ontology/</terms:bibliographicCitation>
        <terms:contributor>Pablo Parrado Gamito</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-17T00:00:00</terms:created>
        <terms:creator>Pablo Parrado Gamito</terms:creator>
        <terms:description>It is intended to formalize and categorize knowledge about the European catalog of high-risk medical devices and in vitro diagnostic devices according to their MDR (EU 2017/745) and IVDR (EU 2017/746) regulatory frameworks. The objective of this ontology is to structure and relate the information coming from the EUDAMED public repository covering the entire regulated part of the life cycle of the devices (Manufacturing, risk classification according to regulations and monitoring of their service (incidents and corrective actions).</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-17T00:00:00</terms:issued>
        <terms:license>https://creativecommons.org/licenses/by/4.0/</terms:license>
        <terms:publisher>Pablo Parrado Gamito (UOC)</terms:publisher>
        <terms:references>Dataset provided in the assignment (dades.xlsx)
DBpedia (https://dbpedia.org)
Linked Open Vocabularies (https://lov.linkeddata.es)
EU Vocabularies (https://op.europa.eu)</terms:references>
        <terms:source>Dataset provided in the assignment (PAC2_Data.zip).
https://dbpedia.org
https://lov.linkeddata
https://op.europa.eu</terms:source>
        <terms:title>European Medical Device Ontology (MDR-IVDR)</terms:title>
        <vann:preferredNamespacePrefix>pac2</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://zatopek73.github.io/PAC2_Ontology#</vann:preferredNamespaceUri>
        <rdfs:label>European Medical Device Ontology (MDR-IVDR).</rdfs:label>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/bibliographicCitation -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/bibliographicCitation"/>
    


    <!-- http://purl.org/dc/terms/contributor -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/contributor"/>
    


    <!-- http://purl.org/dc/terms/created -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/issued -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/publisher -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/publisher"/>
    


    <!-- http://purl.org/dc/terms/references -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/references"/>
    


    <!-- http://purl.org/dc/terms/source -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/source"/>
    


    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- http://www.w3.org/2002/07/owl#sameAs -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#sameAs"/>
    


    <!-- vann:preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="vann:preferredNamespacePrefix"/>
    


    <!-- vann:preferredNamespaceUri -->

    <owl:AnnotationProperty rdf:about="vann:preferredNamespaceUri"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2004/02/skos/core#broadMatch -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broadMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#broaderTransitive"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/2004/02/skos/core#broaderTransitive -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broaderTransitive">
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#mappingRelation"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/2004/02/skos/core#mappingRelation -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#mappingRelation">
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrowMatch -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#narrowMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrowerTransitive"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrower -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#narrower">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrowerTransitive -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#narrowerTransitive">
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/2004/02/skos/core#related -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#related">
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- http://www.w3.org/2004/02/skos/core#relatedMatch -->

    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#relatedMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#affectsDeviceType -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#affectsDeviceType">
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Risk"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#DeviceType"/>
        <rdfs:comment>Relates a risk to the type of device it affects. Used to infer associations between risks and devices.</rdfs:comment>
        <rdfs:label>affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#causesRisk -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#causesRisk">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Risk"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Risk"/>
        <rdfs:comment>Relates a risk to another risk that it causes. This property is transitive.</rdfs:comment>
        <rdfs:label>causes risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasAssociatedRisk -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasAssociatedRisk">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Device"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Risk"/>
        <rdfs:comment>Relates a device to risks associated with it. This relationship is derived from the correspondence between device types and affected device types.</rdfs:comment>
        <rdfs:label>has associated risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasCorrectiveActionStatus -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasCorrectiveActionStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#CorrectiveActions"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#CorrectiveActionStatus"/>
        <rdfs:comment>Relates a corrective action to its status, represented as a controlled vocabulary.</rdfs:comment>
        <rdfs:label>has corrective action status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasDeviceRiskClass -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasDeviceRiskClass">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Device"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#DeviceRiskClass"/>
        <rdfs:comment>Relates a device to its regulatory risk classification.</rdfs:comment>
        <rdfs:label>has device risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasDeviceType -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasDeviceType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Device"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#DeviceType"/>
        <rdfs:comment>Relates a device to its device type. This classification enables linking devices with risks.</rdfs:comment>
        <rdfs:label>has device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasIncidentPatientSex -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasIncidentPatientSex">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Incident"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#IncidentPatientSex"/>
        <rdfs:comment>Relates an incident to the patient&apos;s sex category, represented as a controlled vocabulary.</rdfs:comment>
        <rdfs:label>has incident patient sex</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasIncidentType -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasIncidentType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Incident"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#IncidentType"/>
        <rdfs:comment>Relates an incident to its type, modelled as a controlled classification.</rdfs:comment>
        <rdfs:label>has incident type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasManufacturedBy -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasManufacturedBy">
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Device"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Manufacturer"/>
        <rdfs:comment>Relates a device to its manufacturer. Each device is associated with exactly one manufacturer.</rdfs:comment>
        <rdfs:label>has manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasRegulatory -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasRegulatory">
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Device"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#RegulatoryFramework"/>
        <rdfs:comment>Relates a risk to its regulatory framework.</rdfs:comment>
        <rdfs:label>has regulatory</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasRiskCategory -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasRiskCategory">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Risk"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#RiskCategory"/>
        <rdfs:comment>Relates a risk to its category.</rdfs:comment>
        <rdfs:label>has risk category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasRiskProbability -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasRiskProbability">
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Risk"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#RiskProbability"/>
        <rdfs:comment>Relates a risk to its probability level..</rdfs:comment>
        <rdfs:label>has risk probability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasRiskSeverity -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasRiskSeverity">
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Risk"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#RiskSeverity"/>
        <rdfs:comment>Relates a risk to its severity level..</rdfs:comment>
        <rdfs:label>has risk severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#hasRiskType -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#hasRiskType">
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Risk"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#RiskType"/>
        <rdfs:comment>Relates a risk to its defined type.</rdfs:comment>
        <rdfs:label>has risk type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#isAboutDevice -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#isAboutDevice">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Incident"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Device"/>
        <rdfs:comment>Relates an incident to the device involved. Each incident refers to exactly one device.</rdfs:comment>
        <rdfs:label>is about device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#isAboutRisk -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#isAboutRisk">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Incident"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Risk"/>
        <rdfs:comment>Relates an incident to the associated risk. Each incident is linked to exactly one risk.</rdfs:comment>
        <rdfs:label>is about risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#isBasedIn -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#isBasedIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Manufacturer"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Country"/>
        <rdfs:comment>Relates a manufacturer to the country where it is based.</rdfs:comment>
        <rdfs:label>is based in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#isReportedBy -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#isReportedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Incident"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Manufacturer"/>
        <rdfs:comment>Relates an incident to the reporting entity, modelled as a manufacturer in this ontology.</rdfs:comment>
        <rdfs:label>is reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#isReportedIn -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#isReportedIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Incident"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Country"/>
        <rdfs:comment>Relates an incident to the country where it is reported. Each incident is associated with exactly one country.</rdfs:comment>
        <rdfs:label>is reported in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://zatopek73.github.io/PAC2_Ontology#isResponseTo -->

    <owl:ObjectProperty rdf:about="https://zatopek73.github.io/PAC2_Ontology#isResponseTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://zatopek73.github.io/PAC2_Ontology#CorrectiveActions"/>
        <rdfs:range rdf:resource="https://zatopek73.github.io/PAC2_Ontology#Incident"/>
        <rdfs:comment>Relates a corrective action to the incident it addresses. Each corrective action corresponds to exactly one incident.</rdfs:comment>
        <rdfs:label>is response to</rdfs:label>
    </owl:ObjectProperty>
    


